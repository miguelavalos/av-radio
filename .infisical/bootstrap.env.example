# Copy this file to bootstrap.env and fill it with the bootstrap credentials.
# Keep runtime secrets in Infisical, not here.

LOCAL_INFISICAL_PROJECT_ID=
LOCAL_INFISICAL_ENVIRONMENT=dev
LOCAL_INFISICAL_CLIENT_ID=
LOCAL_INFISICAL_CLIENT_SECRET=
LOCAL_INFISICAL_SITE_URL=https://eu.infisical.com

PRODUCTION_INFISICAL_PROJECT_ID=
PRODUCTION_INFISICAL_ENVIRONMENT=prod
PRODUCTION_INFISICAL_CLIENT_ID=
PRODUCTION_INFISICAL_CLIENT_SECRET=
PRODUCTION_INFISICAL_SITE_URL=https://eu.infisical.com
